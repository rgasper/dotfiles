{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow",
    "web*": "ask",
    "kagi*": "ask",
    "kagi_kagi_summarizer": "deny",
    "bash": {
      "*": "ask",
      "wc*": "allow",
      "head*": "allow",
      "tail*": "allow",
      "rg*": "allow",
      "echo*": "allow",
      "grep*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "git blame*": "allow",
      "git status*": "allow",
      "cd*": "allow",
      "docker ps*": "allow",
      "docker-compose*": "allow",
      "ls*": "allow",
      "test*": "allow",
      "cp*": "allow",
      "poe*": "allow",
      "tg*": "deny",
      "terragrunt*": "deny",
      "tf*": "deny",
      "terraform*": "deny",
      "python3 -m py_compile": "allow",
    }
  },
  "mcp": {
    "mermaid": {
      "type": "local",
      "command": ["claude-mermaid"],
      "enabled": true,
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "kagi": {
      "type": "local",
      "command": ["uvx", "-p", "3.13", "kagimcp"],
      "enabled": true,
      "environment": {
        "KAGI_API_KEY": "SECRETSECRET"
      }
    },
    "linear": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://mcp.linear.app/mcp"],
      "enabled": true,
    },
    "enkodb": {
      "type": "remote",
      "url": "SECRETSECRET"
      "enabled": true,
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
  },
  "default_agent": "jack-h",
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
    "jack-o": {
      "description": "does it all",
      "prompt": "Be concise! Be helpful. delegate questions on looking up or modifying tickets or projects to linear subagent. Delegate to playwright agent for interacting with web browsers.",
      "mode": "primary",
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-7",
      "tools": {
        "*": true,
        "linear*": true,
        "playwright*": true,
      },
      "permission": {
        "kagi*": "ask",
        "webfetch*": "ask",
        "task": {
          "*": "deny",
          "linear": "allow",
          "playwright": "allow",
        }
      }
    },
    "jack-s": {
      "description": "does it all",
      "prompt": "Be concise! Be helpful. delegate questions on looking up or modifying tickets or projects to linear subagent. Delegate to playwright agent for interacting with web browsers.",
      "mode": "primary",
      "model": "amazon-bedrock/anthropic.claude-sonnet-4-5-20250929-v1:0",
      "tools": {
        "*": true,
        "linear*": true,
        "playwright*": true,
      },
      "permission": {
        "kagi*": "ask",
        "webfetch*": "ask",
        "task": {
          "*": "deny",
          "linear": "allow",
          "playwright": "allow",
        }
      }
    },
    "jack-h": {
      "description": "does it all",
      "prompt": "Be concise! Be helpful. delegate questions on looking up or modifying tickets or projects to linear subagent. Delegate to playwright agent for interacting with web browsers.",
      "mode": "primary",
      "model": "amazon-bedrock/anthropic.claude-haiku-4-5-20251001-v1:0",
      "tools": {
        "*": true,
        "linear*": true,
        "playwright*": true,
      },
      "permission": {
        "kagi*": "ask",
        "webfetch*": "ask",
        "task": {
          "*": "deny",
          "linear": "allow",
          "playwright": "allow",
        }
      }
    },
  },
  "lsp": {
    "ty": {
      "command": ["poetry", "run", "ty", "server"],
      "extensions": [".py", ".pyi", ".py3"]
    }
  }
}
